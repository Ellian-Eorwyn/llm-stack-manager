# =============================================================================
# LLM Stack Configuration
# Generated from the active local stack. Copy to llm-stack.env and edit.
STACK_DIR=@STACK_DIR@
LISTEN_HOST=0.0.0.0
# Edit this file to change model paths, ports, GPU assignments, and launch flags.
# All four services source this file at startup.
# After editing, restart the affected service(s):
#   sudo systemctl restart think nothink embed rerank
# =============================================================================

# -----------------------------------------------------------------------------
# Binary path
# Points to the llama-server binary built from llama.cpp.
# -----------------------------------------------------------------------------
LLAMA_SERVER_BIN=@STACK_DIR@/deps/llama.cpp/build/bin/llama-server
BEELLAMA_SERVER_BIN=@STACK_DIR@/deps/beellama.cpp/build/bin/llama-server

# -----------------------------------------------------------------------------
# Model paths
# Update these to point to the actual downloaded GGUF files.
#
# Configure the shared chat backends here.
# `CHAT_MODEL_PATH` powers the generic custom backend.
# `CHAT_DENSE_*` and `CHAT_MOE_*` power the two preset buttons in the UI.
# -----------------------------------------------------------------------------

# Active chat model — used by think and nothink (two-instance mode).
CHAT_MODEL_PATH=@STACK_DIR@/models/Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf
CHAT_MMPROJ_PATH=@STACK_DIR@/models/mmproj-Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-f16.gguf
CHAT_MODEL_NAME=chat-custom

# Secondary chat model — used by chat-backend2 and chat-proxy2.
CHAT2_MODEL_PATH=@STACK_DIR@/models/Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf
CHAT2_MMPROJ_PATH=@STACK_DIR@/models/mmproj-Qwen3.5-27B-Uncensored-HauhauCS-Aggressive-f16.gguf
CHAT2_MODEL_NAME=chat-custom2
CHAT2_CTX_SIZE=262144

# Dense preset — used by chat-backend-dense.
CHAT_DENSE_LABEL="Backend Dense"
CHAT_DENSE_MODEL_NAME=chat-dense
CHAT_DENSE_MODEL_PATH=@STACK_DIR@/models/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-Q6_K.gguf
CHAT_DENSE_MMPROJ_PATH=@STACK_DIR@/models/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-Q6_K.mmproj.gguf

# MoE preset — used by chat-backend-moe.
CHAT_MOE_LABEL="Backend MoE"
CHAT_MOE_MODEL_NAME=chat-moe
CHAT_MOE_MODEL_PATH=@STACK_DIR@/models/Qwen3.6-35B-A3B-uncensored-heretic-Native-MTP-Preserved-Q6_K.gguf
CHAT_MOE_MMPROJ_PATH=@STACK_DIR@/models/Qwen3.6-35B-A3B-uncensored-heretic-Native-MTP-Preserved-Q6_K.mmproj.gguf

# BeeLLaMA preset — used by chat-backend-bee.
CHAT_BEE_LABEL="Backend BeeLLaMA"
CHAT_BEE_MODEL_NAME=chat-bee
CHAT_BEE_MODEL_PATH=@STACK_DIR@/models/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-Q6_K.gguf
CHAT_BEE_MMPROJ_PATH=@STACK_DIR@/models/Qwen3.6-27B-uncensored-heretic-v2-Native-MTP-Preserved-Q6_K.mmproj.gguf

# Per-preset context sizes. Leave equal to CHAT_CTX_SIZE if unsure.
CHAT_DENSE_CTX_SIZE=32768
CHAT_MOE_CTX_SIZE=262144
CHAT_BEE_CTX_SIZE=160000

# Embedding model:
EMBEDDING_MODEL_PATH=@STACK_DIR@/models/Qwen3-Embedding-0.6B-Q8_0.gguf
EMBED2_MODEL_PATH=@STACK_DIR@/models/Qwen3-Embedding-0.6B-Q8_0.gguf
# Example:
# EMBEDDING_MODEL_PATH=@STACK_DIR@/models/Qwen3-Embedding-0.6B-Q8_0.gguf

# Reranker model:
RERANKER_MODEL_PATH=@STACK_DIR@/models/Qwen3-Reranker-0.6B.Q8_0.gguf
# Example:
# RERANKER_MODEL_PATH=@STACK_DIR@/models/Qwen3-Reranker-0.6B-Q8_0.gguf

# Small task model (fast responses, low VRAM):
TASK_MODEL_PATH=@STACK_DIR@/models/Qwen3.5-4B-UD-Q4_K_XL.gguf
TASK_MMPROJ_PATH=@STACK_DIR@/models/Qwen3.5-4B-UD-Q4_K_XL.gguf
TASK_MODEL_NAME=task

# -----------------------------------------------------------------------------
# Chat model launch flags (shared by both chat endpoints)
# -----------------------------------------------------------------------------

# Context window size (tokens) for the generic custom backend.
CHAT_CTX_SIZE=128000

# Number of parallel request slots (controls how many requests can run at once).
CHAT_N_PARALLEL=1
CHAT2_N_PARALLEL=1

# How to place weights across GPUs.
# Valid values:
#   none   = keep the model on one GPU chosen by CHAT_MAIN_GPU
#   layer  = split by layers across GPUs
#   row    = row-wise tensor split across GPUs
#   tensor = parallel tensor+KV sharding across GPUs
CHAT_SPLIT_MODE=layer
CHAT2_SPLIT_MODE=layer

# Tensor split ratio between GPU 0 and GPU 1.
# "1,1" = equal split. Adjust if one GPU has more free VRAM.
# Example: "3,2" would put 60% on GPU 0 and 40% on GPU 1.
CHAT_TENSOR_SPLIT=1,1
CHAT2_TENSOR_SPLIT=1,1

# Number of GPU layers to offload. -1 = offload everything possible.
CHAT_N_GPU_LAYERS=-1
CHAT2_N_GPU_LAYERS=-1

# Optional llama.cpp device override for model offload placement.
# Leave empty to use all visible CUDA devices. Use --list-devices names, e.g. "CUDA0,CUDA1" or "none".
CHAT_DEVICE=CUDA0,CUDA1
CHAT2_DEVICE=CUDA0,CUDA1

# Whether KV cache pages should be offloaded to GPU memory when supported.
# Valid values: on, off
CHAT_KV_OFFLOAD=on
CHAT2_KV_OFFLOAD=on

# Whether host tensor operations should be offloaded to device when supported.
# Valid values: on, off
CHAT_OP_OFFLOAD=on
CHAT2_OP_OFFLOAD=on

# Whether the multimodal projector should be GPU-offloaded when loaded.
# Valid values: on, off
CHAT_MMPROJ_OFFLOAD=on
CHAT2_MMPROJ_OFFLOAD=on

CHAT_MAIN_GPU=1
CHAT2_MAIN_GPU=1

# Flash attention. Reduces VRAM usage for long contexts. Requires GPU.
# Valid values: on, off, auto
CHAT_FLASH_ATTN=on
CHAT2_FLASH_ATTN=on

# KV cache quantization. q8_0 cuts KV cache VRAM roughly in half vs f16.
# Valid values: f32, f16, bf16, q8_0, q5_0, q5_1, q4_0, q4_1, iq4_nl
# Set both to f16 to disable quantization entirely.
CHAT_CACHE_TYPE_K=q8_0
CHAT2_CACHE_TYPE_K=q8_0
CHAT_CACHE_TYPE_V=q8_0
CHAT2_CACHE_TYPE_V=q8_0

# BeeLLaMA KV cache quantization. These are used only by chat-backend-bee.
# Valid values: f32, f16, bf16, q8_0, q6_0, q5_0, q5_1, q4_0, q4_1, iq4_nl,
# turbo2, turbo3, turbo4, turbo2_tcq, turbo3_tcq.
# f32/f16/bf16 are unquantized, q*/iq* are regular KV quantization,
# and turbo*/turbo*_tcq are BeeLLaMA TurboQuant variants.
CHAT_BEE_CACHE_TYPE_K=q5_0
CHAT_BEE_CACHE_TYPE_V=q4_0
CHAT_BEE_GPU_VISIBLE_DEVICES=1
CHAT_BEE_DEVICE=CUDA0,CUDA1
CHAT_BEE_N_GPU_LAYERS=-1
CHAT_BEE_MAIN_GPU=1
CHAT_BEE_SPLIT_MODE=layer
CHAT_BEE_TENSOR_SPLIT=1,1
CHAT_BEE_KV_UNIFIED=on
CHAT_BEE_NO_HOST=off
CHAT_BEE_LOG_TIMESTAMPS=true
CHAT_BEE_LOG_COLORS=off
CHAT_BEE_VERBOSITY=0

# BeeLLaMA DFlash/speculative decoding. Use draft-mtp with MTP-preserved GGUFs.
# Set CHAT_BEE_SPEC_METHOD=dflash and CHAT_BEE_SPEC_DRAFT_MODEL_PATH to enable DFlash.
CHAT_BEE_SPEC_METHOD=off
CHAT_BEE_SPEC_NGRAM_MOD=off
CHAT_BEE_SPEC_DRAFT_MODEL_PATH=""
CHAT_BEE_SPEC_DRAFT_N_GPU_LAYERS=all
CHAT_BEE_SPEC_DRAFT_DEVICES=CUDA0,CUDA1
CHAT_BEE_SPEC_DRAFT_CTX_SIZE=256
CHAT_BEE_SPEC_DRAFT_TYPE_K=f16
CHAT_BEE_SPEC_DRAFT_TYPE_V=f16
CHAT_BEE_SPEC_DRAFT_N_MAX=16
CHAT_BEE_SPEC_DRAFT_N_MIN=0
CHAT_BEE_SPEC_DRAFT_P_MIN=0.0
CHAT_BEE_SPEC_DRAFT_P_SPLIT=0.10
CHAT_BEE_SPEC_NGRAM_MOD_N_MATCH=24
CHAT_BEE_SPEC_NGRAM_MOD_N_MIN=48
CHAT_BEE_SPEC_NGRAM_MOD_N_MAX=64
CHAT_BEE_SPEC_DRAFT_TOP_K=1
CHAT_BEE_SPEC_DRAFT_TEMP=0.0
CHAT_BEE_SPEC_BRANCH_BUDGET=0
CHAT_BEE_SPEC_DFLASH_CROSS_CTX=512
CHAT_BEE_SPEC_DFLASH_MAX_SLOTS=0

# BeeLLaMA adaptive draft-max controller.
CHAT_BEE_SPEC_DM_ADAPTIVE=on
CHAT_BEE_SPEC_DM_CONTROLLER=profit
CHAT_BEE_SPEC_DM_PROBE_INTERVAL=16
CHAT_BEE_SPEC_DM_PROBE_FRACTION=0.25
CHAT_BEE_SPEC_DM_EXPLORE_INTERVAL=12
CHAT_BEE_SPEC_DM_OFF_DWELL=8
CHAT_BEE_SPEC_DM_FRINGE_MIN=0.30
CHAT_BEE_SPEC_DM_FRINGE_MAX=0.50
CHAT_BEE_SPEC_DM_MIN_REACH=3
CHAT_BEE_SPEC_DM_PROFIT_MIN=0.05
CHAT_BEE_SPEC_DM_PROFIT_RAISE_MARGIN=0.05
CHAT_BEE_SPEC_DM_PROFIT_LOWER_MARGIN=0.05
CHAT_BEE_SPEC_DM_PROFIT_EWMA_ALPHA=0.15
CHAT_BEE_SPEC_DM_PROFIT_MIN_SAMPLES=3
CHAT_BEE_SPEC_DM_PROFIT_WARMUP=0
CHAT_BEE_SPEC_DM_PROFIT_BASELINE_INTERVAL=1024

# BeeLLaMA reasoning-loop protection.
CHAT_BEE_REASONING=auto
CHAT_BEE_REASONING_BUDGET=-1
CHAT_BEE_REASONING_LOOP_GUARD=force-close
CHAT_BEE_REASONING_LOOP_MIN_TOKENS=1024
CHAT_BEE_REASONING_LOOP_WINDOW=2048
CHAT_BEE_REASONING_LOOP_MAX_PERIOD=512
CHAT_BEE_REASONING_LOOP_MIN_COVERAGE=768
CHAT_BEE_REASONING_LOOP_CHECK_INTERVAL=32
CHAT_BEE_REASONING_LOOP_INTERVENTIONS=1

# BeeLLaMA DFlash diagnostics. Leave empty/off for normal serving.
CHAT_BEE_DFLASH_PROFILE=""
CHAT_BEE_DFLASH_PROFILE_SYNC_SPLIT=off
CHAT_BEE_DFLASH_DEBUG=off
CHAT_BEE_DFLASH_CRASH_TRACE=off
CHAT_BEE_DFLASH_INPUT_DEBUG=off
CHAT_BEE_DFLASH_VERBOSE_CONTRACT=off
CHAT_BEE_DFLASH_FORCE_CPU_CROSS=off
CHAT_BEE_DFLASH_VERIFY_PAD=off
CHAT_BEE_DFLASH_SHARED_DRAFT_BATCH=on
CHAT_BEE_DFLASH_GPU_RING=on
CHAT_BEE_DFLASH_MULTI_GPU_TAPE=on
CHAT_BEE_DFLASH_MAX_CTX=""
CHAT_BEE_DFLASH_KV_CACHE_MODE=both
CHAT_BEE_CUSTOM_ARGS_JSON="[]"

# Server prompt-cache RAM in MiB and context checkpoints. Set either to 0 to disable.
CHAT_CACHE_RAM=8192
CHAT2_CACHE_RAM=8192
CHAT_CTX_CHECKPOINTS=32
CHAT2_CTX_CHECKPOINTS=32
CHAT_CACHE_IDLE_SLOTS=on
CHAT2_CACHE_IDLE_SLOTS=on
CHAT_CACHE_REUSE=0
CHAT2_CACHE_REUSE=0
CHAT_SWA_FULL=off
CHAT2_SWA_FULL=off

# Memory mapping. "true" loads the full model into RAM at startup (no page faults).
CHAT_NO_MMAP=true
CHAT2_NO_MMAP=true

# Memory locking. "true" prevents the OS from swapping model weights to disk.
CHAT_MLOCK=true
CHAT2_MLOCK=true

# CPU thread counts. -1 lets llama.cpp choose automatically.
CHAT_THREADS=-1
CHAT2_THREADS=-1
CHAT_THREADS_BATCH=-1
CHAT2_THREADS_BATCH=-1

# Prefill batch sizes. Larger = faster prompt processing, more VRAM during prefill.
CHAT_BATCH_SIZE=2048
CHAT2_BATCH_SIZE=2048
CHAT_UBATCH_SIZE=512
CHAT2_UBATCH_SIZE=512

# Sampling parameters for chat models.
CHAT_TEMP=1.0
CHAT2_TEMP=1.0
CHAT_TOP_P=0.95
CHAT2_TOP_P=0.95
CHAT_TOP_K=20
CHAT2_TOP_K=20
CHAT_MIN_P=0.00
CHAT2_MIN_P=0.00

# Native tool calling via Jinja2 templates (--jinja flag).
# Enables OpenAI-compatible tool/function calling in chat completions.
# Valid values: on, off
CHAT_JINJA=on
CHAT2_JINJA=on

# Optional custom Jinja template from config/chat-templates/<id>.jinja.
# Leave empty to use the template embedded in the model metadata.
CHAT_TEMPLATE_ID=""
CHAT2_TEMPLATE_ID=""

# Reasoning format — how thinking/reasoning content is returned in API responses.
# Valid values: none, deepseek, deepseek-legacy
#   none:            leaves thoughts in message.content
#   deepseek:        puts thoughts in message.reasoning_content
#   deepseek-legacy: keeps <think> tags + reasoning_content
CHAT_REASONING_FORMAT=deepseek
CHAT2_REASONING_FORMAT=deepseek

# Auto-fit model to device memory. When "on", llama-server may reduce context size
# to fit in VRAM. Set to "off" to enforce the configured context size exactly.
# Valid values: on, off
CHAT_FIT=off
CHAT2_FIT=off
CHAT_FIT_TARGET=""
CHAT2_FIT_TARGET=""
CHAT_FIT_CTX=4096
CHAT2_FIT_CTX=4096

# Speculative decoding / assisted decoding using a smaller draft GGUF.
# Leave disabled unless the draft model shares a compatible tokenizer and
# actually improves acceptance rate for your target model.
CHAT_SPEC_METHOD=draft-mtp
CHAT2_SPEC_METHOD=draft-mtp
CHAT_SPEC_NGRAM_MOD=off
CHAT2_SPEC_NGRAM_MOD=off
CHAT_SPEC_DRAFT_MODEL_PATH=""
CHAT2_SPEC_DRAFT_MODEL_PATH=""
CHAT_SPEC_DRAFT_N_GPU_LAYERS=auto
CHAT2_SPEC_DRAFT_N_GPU_LAYERS=auto
CHAT_SPEC_DRAFT_DEVICES=""
CHAT2_SPEC_DRAFT_DEVICES=""
CHAT_SPEC_DRAFT_TYPE_K=f16
CHAT2_SPEC_DRAFT_TYPE_K=f16
CHAT_SPEC_DRAFT_TYPE_V=f16
CHAT2_SPEC_DRAFT_TYPE_V=f16
CHAT_SPEC_DRAFT_N_MAX=3
CHAT2_SPEC_DRAFT_N_MAX=3
CHAT_SPEC_DRAFT_N_MIN=0
CHAT2_SPEC_DRAFT_N_MIN=0
CHAT_SPEC_DRAFT_P_MIN=0.75
CHAT2_SPEC_DRAFT_P_MIN=0.75
CHAT_SPEC_DRAFT_P_SPLIT=0.10
CHAT2_SPEC_DRAFT_P_SPLIT=0.10
CHAT_SPEC_NGRAM_MOD_N_MATCH=24
CHAT2_SPEC_NGRAM_MOD_N_MATCH=24
CHAT_SPEC_NGRAM_MOD_N_MIN=48
CHAT2_SPEC_NGRAM_MOD_N_MIN=48
CHAT_SPEC_NGRAM_MOD_N_MAX=64
CHAT2_SPEC_NGRAM_MOD_N_MAX=64
CHAT_SPEC_NGRAM_SIZE_N=12
CHAT2_SPEC_NGRAM_SIZE_N=12
CHAT_SPEC_NGRAM_SIZE_M=48
CHAT2_SPEC_NGRAM_SIZE_M=48
CHAT_SPEC_NGRAM_MIN_HITS=1
CHAT2_SPEC_NGRAM_MIN_HITS=1

# Prefix log lines with timestamp and service name.
CHAT_LOG_PREFIX=true
CHAT2_LOG_PREFIX=true

# Which GPUs are visible to the chat services (comma-separated device indices).
CHAT_GPU_VISIBLE_DEVICES=1
CHAT2_GPU_VISIBLE_DEVICES=1

# Internal backend port and host used when running the shared backend + proxy.
# The backend binds here (localhost only); the proxy exposes thinking/chat/code ports.
# Only used by chat-backend and chat-proxy services.
CHAT_BACKEND_HOST=127.0.0.1
CHAT_BACKEND_PORT=8010
CHAT2_BACKEND_PORT=8020

# Proxy-to-backend socket timeouts.
# Keep connect bounded so dead backends fail fast.
# Disable the read timeout so long-running coding/chat turns are not cut off.
BACKEND_CONNECT_TIMEOUT_SEC=10
BACKEND_READ_TIMEOUT_SEC=off

# -----------------------------------------------------------------------------
# Embedding model launch flags
# -----------------------------------------------------------------------------
EMBED_N_GPU_LAYERS=-1
EMBED_CTX_SIZE=8192
EMBED_N_PARALLEL=1
EMBED_THREADS=-1
EMBED_THREADS_BATCH=-1
EMBED_SPLIT_MODE=layer
EMBED_TENSOR_SPLIT=1
EMBED_FLASH_ATTN=on
EMBED_CACHE_TYPE_K=f16
EMBED_CACHE_TYPE_V=f16
EMBED_BATCH_SIZE=2048
EMBED_UBATCH_SIZE=512
EMBED_NO_MMAP=true
EMBED_MLOCK=true

# GPU device for the embedding model (single GPU).
EMBED_GPU_VISIBLE_DEVICES=0

# Sampling / formatting controls (kept in parity with chat settings).
EMBED_TEMP=1.0
EMBED_TOP_P=0.95
EMBED_TOP_K=20
EMBED_MIN_P=0.00
EMBED_JINJA=off
EMBED_REASONING_FORMAT=none
EMBED_FIT=off

# Prefix log lines with timestamp and service name.
EMBED_LOG_PREFIX=true

# -----------------------------------------------------------------------------
# Secondary Embedding backend
# -----------------------------------------------------------------------------
EMBED2_N_GPU_LAYERS=-1
EMBED2_CTX_SIZE=8192
EMBED2_N_PARALLEL=1
EMBED2_THREADS=-1
EMBED2_THREADS_BATCH=-1
EMBED2_SPLIT_MODE=layer
EMBED2_TENSOR_SPLIT=1
EMBED2_FLASH_ATTN=on
EMBED2_CACHE_TYPE_K=f16
EMBED2_CACHE_TYPE_V=f16
EMBED2_BATCH_SIZE=2048
EMBED2_UBATCH_SIZE=512
EMBED2_NO_MMAP=true
EMBED2_MLOCK=true
EMBED2_GPU_VISIBLE_DEVICES=0
EMBED2_TEMP=1.0
EMBED2_TOP_P=0.95
EMBED2_TOP_K=20
EMBED2_MIN_P=0.00
EMBED2_JINJA=off
EMBED2_REASONING_FORMAT=none
EMBED2_FIT=off
EMBED2_LOG_PREFIX=true

# -----------------------------------------------------------------------------
# Reranker model launch flags
# -----------------------------------------------------------------------------
RERANK_N_GPU_LAYERS=-1
RERANK_CTX_SIZE=8192
RERANK_N_PARALLEL=1
RERANK_THREADS=-1
RERANK_THREADS_BATCH=-1
RERANK_SPLIT_MODE=layer
RERANK_TENSOR_SPLIT=1
RERANK_FLASH_ATTN=on
RERANK_CACHE_TYPE_K=f16
RERANK_CACHE_TYPE_V=f16
RERANK_BATCH_SIZE=4096
RERANK_UBATCH_SIZE=512
RERANK_NO_MMAP=false
RERANK_MLOCK=false

# GPU device for the reranker model (single GPU).
# Pin to GPU 1 so it doesn't compete with the embedding model on GPU 0.
RERANK_GPU_VISIBLE_DEVICES=0

# Sampling / formatting controls (kept in parity with chat settings).
RERANK_TEMP=1.0
RERANK_TOP_P=0.95
RERANK_TOP_K=20
RERANK_MIN_P=0.00
RERANK_JINJA=off
RERANK_REASONING_FORMAT=none
RERANK_FIT=off

# Prefix log lines with timestamp and service name.
RERANK_LOG_PREFIX=true

# -----------------------------------------------------------------------------
# Task model launch flags (small fast model, single GPU)
# -----------------------------------------------------------------------------

# Native tool calling via Jinja2 templates (--jinja flag).
# Valid values: on, off
TASK_JINJA=on

# Enable thinking/reasoning for task model.
# Valid values: on, off
TASK_THINKING=on

# Reasoning format — how thinking/reasoning content is returned in API responses.
# Valid values: none, deepseek, deepseek-legacy
TASK_REASONING_FORMAT=deepseek

# Auto-fit model to device memory. When "on", llama-server may reduce context size
# to fit in VRAM. Set to "off" to enforce the configured context size exactly.
# Valid values: on, off
TASK_FIT=off
TASK_FIT_TARGET=""
TASK_FIT_CTX=4096

TASK_N_GPU_LAYERS=-1
TASK_MAIN_GPU=1
TASK_DEVICE=""
TASK_CTX_SIZE=32000
TASK_N_PARALLEL=1
TASK_THREADS=-1
TASK_THREADS_BATCH=-1
TASK_SPLIT_MODE=layer
TASK_TENSOR_SPLIT=1,1
TASK_KV_OFFLOAD=on
TASK_OP_OFFLOAD=on
TASK_MMPROJ_OFFLOAD=on
TASK_BATCH_SIZE=2048
TASK_UBATCH_SIZE=512
TASK_FLASH_ATTN=on
TASK_CACHE_TYPE_K=q8_0
TASK_CACHE_TYPE_V=q8_0
TASK_CACHE_RAM=8192
TASK_CTX_CHECKPOINTS=32
TASK_CACHE_IDLE_SLOTS=on
TASK_CACHE_REUSE=0
TASK_SWA_FULL=off

# Memory mapping and locking for task model.
TASK_NO_MMAP=false
TASK_MLOCK=false

# Sampling parameters for task model.
TASK_TEMP=.7
TASK_TOP_P=0.95
TASK_TOP_K=20
TASK_MIN_P=0.00
TASK_PRESENCE_PENALTY=0.00
TASK_REPEAT_PENALTY=1.00

TASK_CUSTOM_ARGS_JSON="[]"

# Speculative decoding / assisted decoding for the task model.
# Same options as CHAT_SPEC_* but independent for the task service.
TASK_SPEC_METHOD=off
TASK_SPEC_NGRAM_MOD=off
TASK_SPEC_DRAFT_MODEL_PATH=""
TASK_SPEC_DRAFT_N_GPU_LAYERS=auto
TASK_SPEC_DRAFT_DEVICES=""
TASK_SPEC_DRAFT_TYPE_K=f16
TASK_SPEC_DRAFT_TYPE_V=f16
TASK_SPEC_DRAFT_N_MAX=6
TASK_SPEC_DRAFT_N_MIN=0
TASK_SPEC_DRAFT_P_MIN=0.75
TASK_SPEC_DRAFT_P_SPLIT=0.10
TASK_SPEC_NGRAM_MOD_N_MATCH=24
TASK_SPEC_NGRAM_MOD_N_MIN=48
TASK_SPEC_NGRAM_MOD_N_MAX=64
TASK_SPEC_NGRAM_SIZE_N=12
TASK_SPEC_NGRAM_SIZE_M=48
TASK_SPEC_NGRAM_MIN_HITS=1

TASK_LOG_PREFIX=true

# GPU device for the task model. Defaults to GPU 0; change if load is uneven.
TASK_GPU_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# OCR model launch flags (GLM-OCR multimodal backend)
# -----------------------------------------------------------------------------
OCR_MODEL_PATH=@STACK_DIR@/models/GLM-OCR-F16.gguf
OCR_MMPROJ_PATH=""
OCR_MODEL_NAME=ocr
OCR_HOST=${LISTEN_HOST}
OCR_PORT=8009
OCR_CTX_SIZE=8192
OCR_N_PARALLEL=1
OCR_THREADS=-1
OCR_THREADS_BATCH=-1
OCR_N_GPU_LAYERS=-1
OCR_MAIN_GPU=0
OCR_DEVICE=""
OCR_SPLIT_MODE=layer
OCR_TENSOR_SPLIT=auto
OCR_KV_OFFLOAD=on
OCR_OP_OFFLOAD=on
OCR_MMPROJ_OFFLOAD=on
OCR_BATCH_SIZE=2048
OCR_UBATCH_SIZE=512
OCR_FLASH_ATTN=on
OCR_CACHE_TYPE_K=f16
OCR_CACHE_TYPE_V=f16
OCR_NO_MMAP=false
OCR_MLOCK=false
# OCR_GPU_VISIBLE_DEVICES controls which GPUs the OCR llama-server can see.
# Use 0 or 1 for one GPU, or 0,1 with OCR_SPLIT_MODE=layer/row/tensor to split across both.
OCR_GPU_VISIBLE_DEVICES=0,1
OCR_PROMPT="OCR"
OCR_TEMP=0.1
OCR_TOP_P=0.95
OCR_TOP_K=1
OCR_MIN_P=0.00
OCR_FIT=off
OCR_LOG_PREFIX=true
OCR_CUSTOM_ARGS_JSON="[]"

# -----------------------------------------------------------------------------
# GLM-OCR SDK document parser (local/self-hosted, no MaaS/cloud OCR calls)
# -----------------------------------------------------------------------------
GLMOCR_SDK_ENABLED=on
GLMOCR_SDK_HOST=${LISTEN_HOST}
GLMOCR_SDK_PORT=5002
GLMOCR_PUBLIC_URL=http://127.0.0.1:5002/glmocr/parse
GLMOCR_SDK_LOG_LEVEL=INFO
GLMOCR_OCR_API_MODE=openai
GLMOCR_OCR_API_URL=""
GLMOCR_OCR_REQUEST_TIMEOUT=120
GLMOCR_OCR_CONNECT_TIMEOUT=30
GLMOCR_OCR_RETRY_MAX_ATTEMPTS=2
GLMOCR_OCR_CONNECTION_POOL_SIZE=128
GLMOCR_MAX_WORKERS=16
GLMOCR_PAGE_MAXSIZE=100
GLMOCR_REGION_MAXSIZE=800
GLMOCR_PAGE_MAX_TOKENS=8192
GLMOCR_PAGE_TEMPERATURE=0.0
GLMOCR_PAGE_TOP_P=0.00001
GLMOCR_PAGE_TOP_K=1
GLMOCR_PAGE_REPETITION_PENALTY=1.1
GLMOCR_IMAGE_FORMAT=JPEG
GLMOCR_MIN_PIXELS=12544
GLMOCR_MAX_PIXELS=71372800
GLMOCR_PDF_DPI=200
GLMOCR_PDF_MAX_PAGES=""
GLMOCR_LAYOUT_MODEL_DIR=PaddlePaddle/PP-DocLayoutV3_safetensors
GLMOCR_LAYOUT_DEVICE=""
GLMOCR_LAYOUT_CUDA_VISIBLE_DEVICES=""
GLMOCR_LAYOUT_THRESHOLD=0.3
GLMOCR_LAYOUT_BATCH_SIZE=1
GLMOCR_LAYOUT_WORKERS=1
GLMOCR_LAYOUT_USE_POLYGON=off
GLMOCR_OUTPUT_FORMAT=both
GLMOCR_MERGE_FORMULA_NUMBERS=on
GLMOCR_MERGE_TEXT_BLOCKS=on
GLMOCR_FORMAT_BULLET_POINTS=on
GLMOCR_PROMPT_TEXT="Text Recognition:"
GLMOCR_PROMPT_TABLE="Table Recognition:"
GLMOCR_PROMPT_FORMULA="Formula Recognition:"
GLMOCR_ADVANCED_CONFIG_JSON="{}"

# -----------------------------------------------------------------------------
# SearXNG metasearch service
# -----------------------------------------------------------------------------
SEARXNG_ENABLED=on
SEARXNG_BASE_URL=http://127.0.0.1/searxng/
SEARXNG_PUBLIC_URL=http://127.0.0.1/searxng/
SEARXNG_URL_PATH=/searxng
SEARXNG_INSTANCE_NAME="SearXNG"
SEARXNG_SAFE_SEARCH=2
SEARXNG_AUTOCOMPLETE=duckduckgo
SEARXNG_FORMATS=html,json
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_SECRET=""
SEARXNG_VALKEY_URL=valkey://localhost:6379/0
SEARXNG_HOME=/usr/local/searxng
SEARXNG_SETTINGS_PATH=/etc/searxng/settings.yml
SEARXNG_UWSGI_INI=/etc/uwsgi/apps-available/searxng.ini
SEARXNG_UWSGI_SOCKET=/usr/local/searxng/run/socket
SEARXNG_NGINX_CONF=/etc/nginx/default.apps-available/searxng.conf

# -----------------------------------------------------------------------------
# Playwright browser automation WebSocket server
# -----------------------------------------------------------------------------
PLAYWRIGHT_ENABLED=on
PLAYWRIGHT_HOST=0.0.0.0
PLAYWRIGHT_PORT=3001
PLAYWRIGHT_UPSTREAM_PORT=13001
PLAYWRIGHT_URL_PATH=/playwright
PLAYWRIGHT_PUBLIC_WS_URL=ws://127.0.0.1/playwright/
PLAYWRIGHT_PUBLIC_HTTP_URL=http://127.0.0.1/playwright/
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_INSTALL_BROWSERS=on
PLAYWRIGHT_BROWSERS_PATH=@STACK_DIR@/playwright/browsers
PLAYWRIGHT_NODE_ENV=production
PLAYWRIGHT_NGINX_CONF=/etc/nginx/default.apps-available/playwright.conf

# -----------------------------------------------------------------------------
# Port assignments
# -----------------------------------------------------------------------------
THINK_PORT=8003
NOTHINK_PORT=8004
CODE_PORT=8008

# Secondary Ports for proxy 2
THINK2_PORT=8103
NOTHINK2_PORT=8104
CODE2_PORT=8108

# Model names advertised by the proxy on /v1/models.
THINK_MODEL_NAME=think
NOTHINK_MODEL_NAME=chat
CODE_MODEL_NAME=code

EMBED_MODEL_NAME=embed
EMBED2_MODEL_NAME=embed2
RERANK_MODEL_NAME=rank

# Proxy endpoint configuration (all three endpoints share the same backend model).
# Chat always forces thinking off.
# Thinking always forces thinking on.
# Code uses CODE_THINKING and CODE_* request overrides.
CODE_THINKING=on
CODE_JINJA=on
CODE_CTX_SIZE=262144
CODE_N_PARALLEL=1
CODE_THREADS=-1
CODE_THREADS_BATCH=-1
CODE_N_GPU_LAYERS=-1
CODE_SPLIT_MODE=layer
CODE_TENSOR_SPLIT=1,1
CODE_FLASH_ATTN=on
CODE_CACHE_TYPE_K=q8_0
CODE_CACHE_TYPE_V=q8_0
CODE_BATCH_SIZE=4096
CODE_UBATCH_SIZE=2048
CODE_NO_MMAP=true
CODE_MLOCK=true
CODE_GPU_VISIBLE_DEVICES=0,1
CODE_TEMP=0.6
CODE_MAX_TOKENS=0
CODE_TOP_P=0.95
CODE_TOP_K=20
CODE_MIN_P=0.00
CODE_REASONING_FORMAT=deepseek
CODE_FIT=off

EMBED_PORT=8005
EMBED2_PORT=8011
RERANK_PORT=8006
TASK_PORT=8007

# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Web manager
# -----------------------------------------------------------------------------
LLM_MANAGER_PORT=8077
LLM_MANAGER_HOST=0.0.0.0


# -----------------------------------------------------------------------------
# Local Honcho memory service (self-hosted, local-model routed)
# -----------------------------------------------------------------------------
HONCHO_ENABLED=on
HONCHO_HOST=127.0.0.1
HONCHO_PORT=8090
HONCHO_DIR=@STACK_DIR@/deps/honcho
HONCHO_ENV_FILE=@STACK_DIR@/config/honcho.env
HONCHO_URL=http://${HONCHO_HOST}:${HONCHO_PORT}
HONCHO_WORKSPACE=hermes
HONCHO_USER_PEER=@SERVICE_USER@
HONCHO_AI_PEER=hermes
HONCHO_CONFIGURE_HERMES=on
HONCHO_INSTALL_DATASTORES=on

# Honcho uses OpenAI-compatible local endpoints from this stack.
HONCHO_LLM_BASE_URL=http://127.0.0.1:${NOTHINK_PORT}/v1
HONCHO_LLM_MODEL=${NOTHINK_MODEL_NAME}
HONCHO_EMBED_BASE_URL=http://127.0.0.1:${EMBED_PORT}/v1
HONCHO_EMBED_MODEL=${EMBED_MODEL_NAME}
HONCHO_EMBED_VECTOR_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# Memory Gateway (inside chat-proxy)
# -----------------------------------------------------------------------------
# Graphiti is not installed by the v1 core repo. Keep this off unless you add a
# compatible memory service and point MEMORY_GRAPHITI_BASE_URL at it.
MEMORY_GATEWAY_ENABLED=off
MEMORY_ENABLE_THINK=on
MEMORY_ENABLE_NOTHINK=on
MEMORY_ENABLE_CODE=off
MEMORY_GRAPHITI_BASE_URL=http://127.0.0.1:8070
MEMORY_GRAPHITI_TIMEOUT_SEC=0.35
MEMORY_GRAPHITI_COOLDOWN_SEC=30
MEMORY_INJECTION_MODE=system
MEMORY_MAX_FACTS=8
MEMORY_MAX_FACT_CHARS=220
MEMORY_MAX_BLOCK_CHARS=1800
MEMORY_MAX_QUERY_MESSAGES=6
MEMORY_INCLUDE_SYSTEM_IN_QUERY=off
MEMORY_MAX_INGEST_CHARS=4000
MEMORY_GROUP_HEADER_PRIORITY=x-conversation-id,x-session-id,x-chat-id,x-openwebui-chat-id
MEMORY_GROUP_FALLBACK_SALT=llm-stack
MEMORY_FAIL_OPEN=on

NOTHINK_PRESERVE_THINKING=off
NOTHINK_REASONING_STREAM_MODE=hidden

NOTHINK_JINJA=on

NOTHINK_REASONING_FORMAT=deepseek

NOTHINK_TEMP=0.7
NOTHINK_MAX_TOKENS=0

NOTHINK_TOP_P=0.95

NOTHINK_TOP_K=20

NOTHINK_MIN_P=0.00

CHAT_CUSTOM_ARGS_JSON="[]"
CHAT2_CUSTOM_ARGS_JSON="[]"

THINK_TEMP=0.7
THINK_MAX_TOKENS=0

THINK_TOP_P=0.95

THINK_TOP_K=20

THINK_MIN_P=0.00

THINK_REASONING_FORMAT=deepseek

THINK_JINJA=on

THINK_PRESERVE_THINKING=on
# hidden=reasoning_content only; mirror=reasoning_content+content; content=visible content only.
THINK_REASONING_STREAM_MODE=content

CODE_PRESERVE_THINKING=on
CODE_REASONING_STREAM_MODE=content

THINK_PRESENCE_PENALTY=0.00

THINK_REPEAT_PENALTY=1.00

NOTHINK_PRESENCE_PENALTY=0.00

NOTHINK_REPEAT_PENALTY=1.00

CODE_PRESENCE_PENALTY=0.00

CODE_REPEAT_PENALTY=1.00
