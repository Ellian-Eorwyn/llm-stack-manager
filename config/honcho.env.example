# =============================================================================
# Local Honcho Runtime Configuration
# Generated by install.sh from this template when config/honcho.env is missing.
# This file is local-only and should not be committed.
# =============================================================================

DB_CONNECTION_URI=postgresql+psycopg://honcho:@HONCHO_DB_PASSWORD@@127.0.0.1:5432/honcho
CACHE_ENABLED=true
CACHE_URL=redis://127.0.0.1:6379/0?suppress=true
AUTH_USE_AUTH=false
SENTRY_ENABLED=false
TELEMETRY_ENABLED=false
METRICS_ENABLED=false
DREAM_ENABLED=false
LOG_LEVEL=INFO

# Route all Honcho reasoning/summarization/dream calls through this stack's
# local OpenAI-compatible llama.cpp proxy.
LLM_OPENAI_API_KEY=local
DERIVER_MODEL_CONFIG__TRANSPORT=openai
DERIVER_MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DERIVER_MODEL_CONFIG__MAX_OUTPUT_TOKENS=4096
SUMMARY_MODEL_CONFIG__TRANSPORT=openai
SUMMARY_MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DREAM_DEDUCTION_MODEL_CONFIG__TRANSPORT=openai
DREAM_DEDUCTION_MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DREAM_DEDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DREAM_INDUCTION_MODEL_CONFIG__TRANSPORT=openai
DREAM_INDUCTION_MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DREAM_INDUCTION_MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DIALECTIC_LEVELS__low__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__low__MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DIALECTIC_LEVELS__low__MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DIALECTIC_LEVELS__medium__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__medium__MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DIALECTIC_LEVELS__medium__MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DIALECTIC_LEVELS__high__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__high__MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DIALECTIC_LEVELS__high__MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@
DIALECTIC_LEVELS__max__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__max__MODEL_CONFIG__MODEL=@HONCHO_LLM_MODEL@
DIALECTIC_LEVELS__max__MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_LLM_BASE_URL@

# Route Honcho embeddings through the stack embedding server.
EMBEDDING_VECTOR_DIMENSIONS=@HONCHO_EMBED_VECTOR_DIMENSIONS@
EMBED_MESSAGES=true
EMBEDDING_MODEL_CONFIG__TRANSPORT=openai
EMBEDDING_MODEL_CONFIG__MODEL=@HONCHO_EMBED_MODEL@
EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=@HONCHO_EMBED_BASE_URL@
