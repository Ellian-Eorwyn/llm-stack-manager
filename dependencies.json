{
  "version": 1,
  "dependencies": [
    {
      "name": "llama.cpp",
      "type": "git-cmake",
      "repo": "https://github.com/ggml-org/llama.cpp.git",
      "ref": "846e991ec3c7ccec49112ff2c5b00b710e5f551d",
      "path": "deps/llama.cpp",
      "build_dir": "deps/llama.cpp/build",
      "target": "llama-server",
      "binary": "deps/llama.cpp/build/bin/llama-server",
      "cmake_args": [
        "-DGGML_CUDA=ON",
        "-DCMAKE_BUILD_TYPE=Release"
      ],
      "require_gpu": true
    },
    {
      "name": "honcho",
      "type": "git-uv",
      "repo": "https://github.com/plastic-labs/honcho.git",
      "ref": "main",
      "path": "deps/honcho",
      "uv_args": [
        "sync",
        "--frozen",
        "--no-group",
        "dev"
      ],
      "enabled_env": "HONCHO_ENABLED"
    }
  ]
}
